---
import { languages, getLangFromUrl, getLocalizedPath, type Lang } from '../i18n/translations';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

function getPathWithoutLang(path: string): string {
  const segments = path.split('/').filter(Boolean);
  if (segments[0] in languages) {
    return '/' + segments.slice(1).join('/') || '/';
  }
  return path;
}

const basePath = getPathWithoutLang(currentPath);
const otherLang = currentLang === 'en' ? 'cs' : 'en';
const otherLabel = currentLang === 'en' ? 'CS' : 'EN';
---

<a
  href={getLocalizedPath(basePath, otherLang as Lang)}
  style="
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: #999999;
    text-decoration: none;
    transition: color 0.3s ease;
  "
  onmouseover="this.style.color='#1A1A1A'"
  onmouseout="this.style.color='#999999'"
>
  {otherLabel}
</a>
