---
const currentYear = new Date().getFullYear();
---

<footer style="border-top: 1px solid #EAEAEA; background-color: #FAFAFA;">
  <div class="container" style="padding-top: 32px; padding-bottom: 32px; display: flex; justify-content: space-between; align-items: center;">
    <span style="
      font-size: 11px;
      font-weight: 300;
      color: #999999;
      letter-spacing: 0.05em;
      font-family: 'JetBrains Mono', monospace;
    ">&copy; {currentYear} Petr Stanislav</span>
    <div style="display: flex; gap: 24px;">
      <a href="https://github.com/pstanisl" target="_blank" rel="noopener noreferrer"
        style="font-size: 12px; font-weight: 400; letter-spacing: 0.1em; text-transform: uppercase; color: #999999; text-decoration: none; transition: color 0.3s ease;"
        onmouseover="this.style.color='#1E4D6B'" onmouseout="this.style.color='#999999'">GitHub</a>
      <a href="https://www.linkedin.com/in/pstanisl/" target="_blank" rel="noopener noreferrer"
        style="font-size: 12px; font-weight: 400; letter-spacing: 0.1em; text-transform: uppercase; color: #999999; text-decoration: none; transition: color 0.3s ease;"
        onmouseover="this.style.color='#1E4D6B'" onmouseout="this.style.color='#999999'">LinkedIn</a>
    </div>
  </div>
</footer>
