---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const helpItems = [
  {
    title: t('contact.help.strategy'),
    description: t('contact.help.strategy.description'),
  },
  {
    title: t('contact.help.advisory'),
    description: t('contact.help.advisory.description'),
  },
  {
    title: t('contact.help.speaking'),
    description: t('contact.help.speaking.description'),
  },
  {
    title: t('contact.help.media'),
    description: t('contact.help.media.description'),
  },
];
---

<BaseLayout
  title={`${t('contact.title')} — Petr Stanislav`}
  description={t('contact.subtitle')}
>

  <!-- ─── PAGE HEADER ────────────────────────────────────── -->
  <section style="padding: 64px 0 48px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 16px 0; color: #999999;">{t('contact.title')}</p>
      <h1 style="
        font-size: 2rem;
        font-weight: 300;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: #1A1A1A;
        margin: 0;
        max-width: 480px;
      ">{t('contact.subtitle')}</h1>
    </div>
  </section>

  <!-- ─── INTRO + LINKEDIN ──────────────────────────────── -->
  <section style="padding: 80px 0 80px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 20px 0;">{t('contact.connect')}</p>
      <p style="
        font-size: 0.95rem;
        font-weight: 300;
        color: #6B6B6B;
        line-height: 1.8;
        margin: 0 0 40px 0;
        max-width: 500px;
      ">{t('contact.connect.description')}</p>

      <a
        href="https://www.linkedin.com/in/pstanisl/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-link-primary"
      >
        {t('contact.linkedin')}
      </a>
    </div>
  </section>

  <!-- ─── WHAT I CAN HELP WITH ─────────────────────────── -->
  <section style="padding: 80px 0 80px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 48px 0;">{t('contact.help.title')}</p>

      <div class="help-grid">
        {helpItems.map((item) => (
          <div>
            <h3 style="
              font-size: 1rem;
              font-weight: 400;
              color: #1A1A1A;
              margin: 0 0 10px 0;
              letter-spacing: -0.01em;
            ">{item.title}</h3>
            <p style="
              font-size: 0.85rem;
              font-weight: 300;
              color: #6B6B6B;
              line-height: 1.7;
              margin: 0;
            ">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SCHEDULE ─────────────────────────────────────── -->
  <section style="padding: 80px 0 100px;">
    <div class="container">
      <p class="label" style="margin: 0 0 20px 0;">{t('contact.schedule')}</p>
      <p style="
        font-size: 0.95rem;
        font-weight: 300;
        color: #6B6B6B;
        line-height: 1.8;
        margin: 0 0 16px 0;
        max-width: 480px;
      ">{t('contact.schedule.description')}</p>
      <p style="
        font-size: 0.85rem;
        font-weight: 300;
        color: #999999;
        font-style: italic;
        margin: 0;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.02em;
      ">{t('contact.schedule.placeholder')}</p>
    </div>
  </section>

</BaseLayout>

<style>
  .help-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 64px;
  }

  @media (max-width: 700px) {
    .help-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
