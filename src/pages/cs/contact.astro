---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('connect.title')} — Petr Stanislav`}
  description={t('connect.subtext')}
>
  <section style="min-height: 50vh; display: flex; flex-direction: column; justify-content: center; padding: 120px 0;">
    <div class="container">
      <h1 style="font-size: 1.75rem; font-weight: 300; letter-spacing: -0.01em; margin: 0 0 16px 0;">
        {t('connect.heading')}
      </h1>
      <p style="font-size: 0.9rem; color: var(--color-text-secondary); margin: 0 0 32px 0; max-width: 480px;">
        {t('connect.subtext')}
      </p>
      <a href="https://www.linkedin.com/in/pstanisl/" target="_blank" rel="noopener noreferrer" class="btn-link">
        {t('connect.cta')}
      </a>
      <!-- Future: Calendly link here -->
    </div>
  </section>
</BaseLayout>
