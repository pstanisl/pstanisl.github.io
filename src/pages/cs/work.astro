---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allTalks = await getCollection('speaking');
const allProjects = await getCollection('projects');

const talks = allTalks
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(talk => ({
    type: 'talk' as const,
    title: talk.data.title,
    description: talk.data.description,
    year: talk.data.date.getFullYear().toString(),
    role: t(`type.${talk.data.type}` as any),
    tags: [talk.data.venue],
    videoUrl: talk.data.videoUrl,
    slidesUrl: talk.data.slidesUrl,
    sortDate: talk.data.date.getTime(),
  }));

const projects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .map(project => ({
    type: 'project' as const,
    title: project.data.title,
    description: project.data.description,
    year: project.data.year || '',
    role: project.data.role,
    tags: project.data.technologies,
    url: project.data.url,
    github: project.data.github,
    sortDate: project.data.order * -1,
  }));

const allWork = [...projects, ...talks];
---

<BaseLayout
  title={`${t('work.title')} — Petr Stanislav`}
  description={t('work.subtitle')}
>
  <section style="padding: 64px 0 48px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 16px 0; color: #999999;">{t('work.title')}</p>
      <h1 style="font-size: 2rem; font-weight: 300; letter-spacing: -0.01em; line-height: 1.3; margin: 0; max-width: 480px;">
        {t('work.subtitle')}
      </h1>
    </div>
  </section>

  <section style="padding: 80px 0 80px;">
    <div class="container">
      <div id="work-filter" style="display: flex; gap: 24px; margin-bottom: 48px;">
        <button class="filter-btn active" data-filter="all"
          style="font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; background: none; border: none; cursor: pointer; padding: 0 0 4px 0; border-bottom: 1px solid var(--color-text); color: var(--color-text); transition: color 0.3s ease, border-color 0.3s ease;">
          {t('work.filter.all')}
        </button>
        <button class="filter-btn" data-filter="project"
          style="font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; background: none; border: none; cursor: pointer; padding: 0 0 4px 0; border-bottom: 1px solid transparent; color: var(--color-text-muted); transition: color 0.3s ease, border-color 0.3s ease;">
          {t('work.filter.projects')}
        </button>
        <button class="filter-btn" data-filter="talk"
          style="font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; background: none; border: none; cursor: pointer; padding: 0 0 4px 0; border-bottom: 1px solid transparent; color: var(--color-text-muted); transition: color 0.3s ease, border-color 0.3s ease;">
          {t('work.filter.talks')}
        </button>
      </div>

      <div class="work-grid" id="work-list">
        {allWork.map((item) => (
          <div class="work-item" data-type={item.type} style="display: contents;">
            <div style="padding: 28px 24px 28px 0; border-top: 1px solid #EAEAEA; display: flex; flex-direction: column; gap: 4px;">
              <span class="mono" style="font-size: 12px;">{item.year}</span>
              <span class="mono" style="font-size: 11px; color: var(--color-primary); letter-spacing: 0.03em;">{item.role}</span>
            </div>
            <div style="padding: 28px 0; border-top: 1px solid #EAEAEA;">
              <h3 class="work-title" style="font-size: 1rem; font-weight: 400; color: var(--color-text); margin: 0 0 6px 0; letter-spacing: -0.01em; transition: color 0.3s ease;">{item.title}</h3>
              <p style="font-size: 0.85rem; font-weight: 300; color: var(--color-text-secondary); line-height: 1.7; margin: 0 0 14px 0;">{item.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                {item.tags.map((tag: string) => (
                  <span style="font-size: 11px; font-weight: 300; color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 4px 10px; letter-spacing: 0.03em;">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .work-item:hover .work-title {
    color: var(--color-primary);
  }
  .work-item:last-of-type > div:last-child {
    border-bottom: 1px solid #EAEAEA;
  }
  .work-item:last-of-type > div:first-child {
    border-bottom: 1px solid #EAEAEA;
  }

  @media (max-width: 700px) {
    .work-item {
      display: block !important;
    }
    .work-item > div:first-child {
      padding: 24px 0 0 0 !important;
      flex-direction: row !important;
      gap: 12px !important;
    }
    .work-item > div:last-child {
      padding: 12px 0 24px 0 !important;
      border-top: none !important;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.work-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach(b => {
        (b as HTMLElement).style.color = '#999999';
        (b as HTMLElement).style.borderBottomColor = 'transparent';
      });
      (btn as HTMLElement).style.color = '#1A1A1A';
      (btn as HTMLElement).style.borderBottomColor = '#1A1A1A';

      items.forEach(item => {
        const type = item.getAttribute('data-type');
        if (filter === 'all' || type === filter) {
          (item as HTMLElement).style.display = 'contents';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
