---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProjects = await getCollection('projects');

const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const signalEntries = lang === 'cs' ? [
  { date: '2026.04', text: 'Zkoumám AI-first vývojové vzory v <a href="https://elin.ai">Elin.ai</a>. Stavím agentní workflow do produktu.' },
  { date: '2026.03', text: 'Přemýšlím o budoucnosti agentů — kde se autonomní systémy potkávají se skutečnými problémy uživatelů.' },
  { date: '2026.01', text: 'Pomáhám O2 škálovat adopci LLM napříč organizací. Znovu čtu Lemův "Futurologický kongres".' },
] : [
  { date: '2026.04', text: 'Exploring AI-first development patterns at <a href="https://elin.ai">Elin.ai</a>. Building agentic workflows into the product.' },
  { date: '2026.03', text: 'Thinking about the future of agents — where autonomous systems meet real user problems.' },
  { date: '2026.01', text: 'Helping O2 scale LLM adoption across the organization. Reading Lem\'s "The Futurological Congress" again.' },
];
---

<BaseLayout title={`${t('hero.title')} — ${t('hero.subtitle')}`}>

  <!-- Mood 1: Stillness -->
  <section style="min-height: calc(100vh - 49px); display: flex; flex-direction: column; justify-content: center; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="mono" style="font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; margin: 0 0 24px 0;">
        {t('home.hero.label')}
      </p>
      <h1 style="margin: 0 0 20px 0;">{t('hero.title')}</h1>
      <p style="font-size: 1.1rem; font-weight: 300; color: var(--color-text-secondary); line-height: 1.7; max-width: 540px; margin: 0;">
        {t('home.hero.tagline')}
      </p>
      <p class="mono" style="margin-top: 80px; font-size: 11px; letter-spacing: 0.15em; opacity: 0.5;">
        {t('home.hero.scroll')}
      </p>
    </div>
  </section>

  <!-- Mood 2: Evidence -->
  <section style="padding: 100px 0; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 48px 0;">{t('home.work.title')}</p>

      <div class="work-grid">
        {featuredProjects.map((project) => (
          <div class="reveal work-card" style="display: contents;">
            <div style="padding: 28px 24px 28px 0; border-top: 1px solid #EAEAEA; display: flex; flex-direction: column; gap: 4px;">
              <span class="mono" style="font-size: 12px;">{project.data.order === 1 ? '2023 — present' : '2021 — 2023'}</span>
              <span class="mono" style="font-size: 11px; color: var(--color-primary); letter-spacing: 0.03em;">{project.data.role}</span>
            </div>
            <div style="padding: 28px 0; border-top: 1px solid #EAEAEA;">
              <h3 class="work-title" style="font-size: 1.35rem; font-weight: 400; letter-spacing: -0.01em; line-height: 1.35; margin: 0 0 10px 0; transition: color 0.3s ease;">{project.data.title}</h3>
              <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.7; margin: 0 0 14px 0;">{project.data.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                {project.data.technologies.slice(0, 4).map((tech: string) => (
                  <span style="font-size: 11px; font-weight: 300; color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 4px 10px; letter-spacing: 0.03em;">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}

        <div class="reveal work-card" style="display: contents;">
          <div style="padding: 28px 24px 28px 0; border-top: 1px solid #EAEAEA; display: flex; flex-direction: column; gap: 4px;">
            <span class="mono" style="font-size: 12px;">2018 — present</span>
            <span class="mono" style="font-size: 11px; color: var(--color-primary); letter-spacing: 0.03em;">20+ Talks</span>
          </div>
          <div style="padding: 28px 0; border-top: 1px solid #EAEAEA; border-bottom: 1px solid #EAEAEA;">
            <h3 class="work-title" style="font-size: 1.35rem; font-weight: 400; letter-spacing: -0.01em; line-height: 1.35; margin: 0 0 10px 0; transition: color 0.3s ease;">Conference Speaking</h3>
            <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.7; margin: 0 0 14px 0;">AI adoption, LLM integration patterns, and building AI-first products. Keynotes, workshops, podcasts, and panels.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              <span style="font-size: 11px; font-weight: 300; color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 4px 10px; letter-spacing: 0.03em;">MLPrague</span>
              <span style="font-size: 11px; font-weight: 300; color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 4px 10px; letter-spacing: 0.03em;">DataTalk</span>
              <span style="font-size: 11px; font-weight: 300; color: var(--color-text-muted); border: 1px solid var(--color-border); padding: 4px 10px; letter-spacing: 0.03em;">Scriptease</span>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top: 32px;">
        <a href={getLocalizedPath('/work', lang)} class="btn-link">{t('home.work.viewall')}</a>
      </div>
    </div>
  </section>

  <!-- Mood 3: Signal -->
  <section style="padding: 100px 0; border-bottom: 1px solid #EAEAEA; background: var(--color-surface);">
    <div class="container">
      <p class="label" style="margin: 0 0 48px 0;">{t('home.signal.title')}</p>

      <div class="signal-grid">
        {signalEntries.map((entry) => (
          <div class="reveal" style="display: contents;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-text-muted); letter-spacing: 0.05em; padding: 14px 0; border-top: 1px solid var(--color-border);">
              {entry.date}
            </span>
            <span style="font-family: var(--font-mono); font-size: 13px; font-weight: 300; color: var(--color-text-secondary); line-height: 1.8; padding: 14px 0; border-top: 1px solid var(--color-border);"
              set:html={entry.text} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mood 4: Invitation -->
  <section class="reveal" style="padding: 120px 0;">
    <div class="container">
      <h2 style="margin: 0 0 16px 0;">{t('home.connect.heading')}</h2>
      <p style="font-size: 0.9rem; color: var(--color-text-secondary); margin: 0 0 32px 0; max-width: 480px;">
        {t('home.connect.subtext')}
      </p>
      <a href={getLocalizedPath('/contact', lang)} class="btn-link">{t('home.connect.cta')}</a>
    </div>
  </section>

</BaseLayout>

<style>
  .work-card:hover .work-title {
    color: var(--color-primary);
  }

  @media (max-width: 700px) {
    .work-card {
      display: block !important;
    }
    .work-card > div:first-child {
      padding: 24px 0 0 0 !important;
      flex-direction: row !important;
      gap: 12px !important;
      border-bottom: none !important;
    }
    .work-card > div:last-child {
      padding: 12px 0 24px 0 !important;
      border-top: none !important;
    }
    .signal-grid > div {
      display: block !important;
    }
    .signal-grid > div > span:first-child {
      padding: 14px 0 4px 0 !important;
    }
    .signal-grid > div > span:last-child {
      padding: 0 0 14px 0 !important;
      border-top: none !important;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
