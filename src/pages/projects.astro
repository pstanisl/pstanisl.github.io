---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={`${t('projects.title')} — Petr Stanislav`}
  description={t('projects.subtitle')}
>

  <!-- ─── PAGE HEADER ────────────────────────────────────── -->
  <section style="padding: 64px 0 48px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 16px 0; color: #999999;">{t('projects.title')}</p>
      <h1 style="
        font-size: 2rem;
        font-weight: 300;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: #1A1A1A;
        margin: 0;
        max-width: 480px;
      ">{t('projects.subtitle')}</h1>
    </div>
  </section>

  <!-- ─── PROJECTS LIST ────────────────────────────────────── -->
  <section style="padding: 80px 0 80px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">

      {projects.length > 0 ? (
        <div style="display: flex; flex-direction: column;">
          {projects.map((project) => (
            <div class="project-item">
              <div class="project-meta">
                <span class="label" style="color: #1E4D6B; display: block;">{project.data.role.split(' ')[0]}</span>
                <span class="mono" style="display: block; margin-top: 6px; line-height: 1.6;">
                  {project.data.role.split(' ').slice(1).join(' ')}
                </span>
              </div>
              <div class="project-content">
                <h3 style="
                  font-size: 1rem;
                  font-weight: 400;
                  color: #1A1A1A;
                  margin: 0 0 10px 0;
                  letter-spacing: -0.01em;
                ">{project.data.title}</h3>
                <p style="
                  font-size: 0.85rem;
                  font-weight: 300;
                  color: #6B6B6B;
                  line-height: 1.7;
                  margin: 0 0 16px 0;
                ">{project.data.description}</p>

                <!-- Technologies -->
                <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px;">
                  {project.data.technologies.map((tech: string) => (
                    <span style="
                      font-size: 11px;
                      font-weight: 300;
                      color: #999999;
                      border: 1px solid #EAEAEA;
                      padding: 4px 10px;
                      letter-spacing: 0.03em;
                    ">{tech}</span>
                  ))}
                </div>

                <!-- Links -->
                <div style="display: flex; gap: 24px;">
                  {project.data.url && (
                    <a
                      href={project.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-link-primary"
                      style="font-size: 11px;"
                    >
                      {project.data.url.replace('https://', '')} →
                    </a>
                  )}
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-link"
                      style="font-size: 11px;"
                    >
                      GitHub →
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p style="font-size: 0.95rem; font-weight: 300; color: #999999; margin: 0;">
          {t('projects.empty')}
          <a
            href="https://github.com/pstanisl"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #1E4D6B; border-bottom: 1px solid #1E4D6B; padding-bottom: 1px;"
          >
            GitHub
          </a>.
        </p>
      )}

    </div>
  </section>

  <!-- ─── OPEN SOURCE ──────────────────────────────────── -->
  <section style="padding: 80px 0 80px; border-bottom: 1px solid #EAEAEA;">
    <div class="container">
      <p class="label" style="margin: 0 0 20px 0;">{t('projects.opensource')}</p>
      <p style="
        font-size: 0.95rem;
        font-weight: 300;
        color: #6B6B6B;
        line-height: 1.8;
        margin: 0 0 32px 0;
        max-width: 440px;
      ">{t('projects.opensource.description')}</p>
      <a
        href="https://github.com/pstanisl"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-link"
      >
        {t('projects.github')}
      </a>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────── -->
  <section style="padding: 80px 0 100px;">
    <div class="container">
      <p class="label" style="margin: 0 0 24px 0; color: #999999;">{t('projects.cta.title')}</p>
      <p style="
        font-size: 1.4rem;
        font-weight: 300;
        color: #1A1A1A;
        letter-spacing: -0.01em;
        line-height: 1.5;
        margin: 0 0 40px 0;
        max-width: 440px;
      ">{t('projects.cta.description')}</p>
      <a href={getLocalizedPath('/contact', lang)} class="btn-link-primary">
        {t('cta.button')}
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .project-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 32px;
    padding: 32px 0;
    border-top: 1px solid #EAEAEA;
  }
  .project-item:last-child {
    border-bottom: 1px solid #EAEAEA;
  }
  .project-meta { padding-top: 2px; }

  @media (max-width: 700px) {
    .project-item {
      grid-template-columns: 80px 1fr;
      gap: 20px;
    }
  }
</style>
